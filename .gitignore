# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# generated secrets (never commit plaintext passwords)
/scratchpad/

# local Claude Code permission overrides (machine-specific)
.claude/settings.local.json

# typescript
*.tsbuildinfo
next-env.d.ts

# Capacitor Android signing (created manually later, never committed)
android/app/*.keystore
android/app/*.jks
android/key.properties
key.properties
*.keystore

# Android Studio build/IDE artifacts (regenerated locally, not source)
android/.idea/
android/.gradle/
android/app/build/
android/app/release/
android/local.properties

# user-uploaded files (local disk storage, never committed)
public/uploads/
